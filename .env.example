# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# App URL (for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare Turnstile CAPTCHA
# Get your keys from: https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Tencent Cloud COS Configuration (for frontend URL generation)
NEXT_PUBLIC_COS_BUCKET=fluxa-1390058464
NEXT_PUBLIC_COS_REGION=ap-tokyo

# Note: AI API keys and COS secrets are configured in Supabase Edge Function Secrets, not here.
# Go to Supabase Dashboard > Edge Functions > Secrets to configure:
# - OPENAI_API_KEY
# - ANTHROPIC_API_KEY  
# - VOLCENGINE_API_KEY
# - DEFAULT_AI_MODEL (optional, defaults to doubao-seed-1-6-vision-250815)
# - COS_SECRET_ID (Tencent Cloud SecretId)
# - COS_SECRET_KEY (Tencent Cloud SecretKey)
# - COS_BUCKET (optional, defaults to fluxa-1390058464)
# - COS_REGION (optional, defaults to ap-tokyo)
