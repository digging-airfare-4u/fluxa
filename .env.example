# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# App URL (for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare Turnstile CAPTCHA
# Get your keys from: https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Note: AI API keys are configured in Supabase Edge Function Secrets, not here.
# Go to Supabase Dashboard > Edge Functions > Secrets to configure:
# - OPENAI_API_KEY
# - ANTHROPIC_API_KEY  
# - VOLCENGINE_API_KEY
# - DEFAULT_AI_MODEL (optional, defaults to doubao-seed-1-6-vision-250815)
