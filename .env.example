# =========================================================
# Fluxa Environment Variables (.env.example)
# =========================================================
# 说明：
# 1) 本文件用于本地/部署环境变量模板，不要填写真实密钥后提交到仓库。
# 2) 带 NEXT_PUBLIC_ 前缀的变量会暴露到浏览器端。
# 3) Supabase Edge Functions 运行时使用的变量，请在 Supabase Dashboard > Edge Functions > Secrets 配置。


# =========================================================
# 1) Next.js App (frontend + API routes)
# =========================================================

# Supabase 项目 URL（前端与服务端都使用）
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Supabase 匿名公钥（前端可见）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 应用对外访问地址（用于支付 return URL、通知 URL 拼接等）
# 本地开发示例：http://localhost:3000
# 生产示例：https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Service Role（仅服务端使用，绝不能暴露到前端）
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 定时任务鉴权密钥（/api/payments/cron 读取 x-cron-secret）
CRON_SECRET=replace_with_a_long_random_secret


# =========================================================
# 2) Payments - Alipay
# =========================================================

# 支付宝开放平台 App ID
ALIPAY_APP_ID=

# 商户私钥（RSA2，PKCS8 PEM）
ALIPAY_PRIVATE_KEY=

# 支付宝公钥（用于回调验签）
ALIPAY_PUBLIC_KEY=

# 可选：网关地址
# 生产默认：https://openapi.alipay.com/gateway.do
# 沙箱示例：https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_GATEWAY=


# =========================================================
# 3) Payments - WeChat Pay
# =========================================================

# 微信 AppID
WECHAT_PAY_APP_ID=

# 微信商户号
WECHAT_PAY_MCH_ID=

# APIv3 Key（用于通知解密）
WECHAT_PAY_API_V3_KEY=

# 商户私钥（PEM）
WECHAT_PAY_PRIVATE_KEY=

# 商户证书序列号
WECHAT_PAY_SERIAL_NO=

# 微信支付平台公钥（PEM，用于通知签名验真）
WECHAT_PAY_PLATFORM_PUBLIC_KEY=

# 可选：API base
# 生产默认：https://api.mch.weixin.qq.com
# 沙箱可按需要覆盖
WECHAT_PAY_API_BASE=


# =========================================================
# 4) Payments - UnionPay (optional / 当前适配器未完整实现)
# =========================================================

UNIONPAY_MER_ID=
UNIONPAY_SIGN_CERT=
UNIONPAY_SIGN_CERT_PASSWORD=
UNIONPAY_ENCRYPT_KEY=
UNIONPAY_GATEWAY=


# =========================================================
# 5) Security / Provider Config (Next.js server)
# =========================================================

# 用户自定义模型配置加密密钥（建议 32 字节以上）
PROVIDER_ENCRYPTION_SECRET=

# Provider Host allowlist，逗号分隔 host:port
# 例如：api.openai.com:443,api.anthropic.com:443
PROVIDER_HOST_ALLOWLIST=

# 可选：provider revalidation 超时（毫秒）
PROVIDER_REVALIDATION_TIMEOUT_MS=15000


# =========================================================
# 6) Public feature flags (浏览器可见)
# =========================================================

# 是否启用模型配置功能（前端可见）
# true / false
NEXT_PUBLIC_MODEL_CONFIG_ENABLED=false

# 是否启用灵感广场功能（前端可见）
# true / false
NEXT_PUBLIC_INSPIRATION_DISCOVERY_ENABLED=false


# =========================================================
# 7) Cloudflare Turnstile (frontend)
# =========================================================

# 获取地址：https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=


# =========================================================
# 8) COS public config (frontend URL generation)
# =========================================================

NEXT_PUBLIC_COS_BUCKET=fluxa-1390058464
NEXT_PUBLIC_COS_REGION=ap-tokyo


# =========================================================
# 9) Supabase Edge Functions Secrets
# =========================================================
# 以下变量主要在 supabase/functions/* 中通过 Deno.env.get(...) 读取。
# 建议在 Supabase Dashboard > Edge Functions > Secrets 配置。

# ---- Supabase runtime (Edge Functions) ----
# 通常由平台注入；若本地运行需配置
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- AI providers ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VOLCENGINE_API_KEY=
VOLCENGINE_API_URL=
GEMINI_API_KEY=

# ---- Image/Generation provider tunables ----
DEFAULT_AI_MODEL=doubao-seed-1-6-vision-250815
VOLCENGINE_IMAGE_MODEL=doubao-seedream-4-5-251128
GEMINI_IMAGE_API_MODE=
GEMINI_IMAGE_API_URL=
GEMINI_IMAGE_API_KEY=
GEMINI_INLINE_REFERENCE_MAX_BYTES=

# ---- Shared security / feature flags for Edge ----
PROVIDER_ENCRYPTION_SECRET=
PROVIDER_HOST_ALLOWLIST=
MODEL_CONFIG_ENABLED=false

# ---- COS private credentials (Edge uploads) ----
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=fluxa-1390058464
COS_REGION=ap-tokyo
